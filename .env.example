# ==========================================
# GENIA ENVIRONMENT VARIABLES CONFIGURATION
# ==========================================

# ------------------------------------------
# 1. DATABASE (Prisma / PostgreSQL)
# ------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/genia?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/genia?schema=public"

# ------------------------------------------
# 2. APPLICATION URLS
# ------------------------------------------
VITE_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
VITE_VERCEL_ENV="development"
VITE_VERCEL_URL="localhost:3000"

# ------------------------------------------
# 3. AUTHENTICATION (Better Auth / NextAuth)
# ------------------------------------------
BETTER_AUTH_SECRET="your-super-secret-auth-key-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# OAuth Providers (Optional)
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"

GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ------------------------------------------
# 4. STRIPE PAYMENT & AFFILIATE
# ------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ------------------------------------------
# 5. EMAIL SERVICES (Resend)
# ------------------------------------------
EMAIL_MODE="development" # development | production
RESEND_API_KEY="re_123456789"
RESEND_FROM_EMAIL="Genia <notifications@genia.tech>"

# ------------------------------------------
# 6. RATE LIMITING & CACHING (Upstash Redis)
# ------------------------------------------
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_rest_token"

# ------------------------------------------
# 7. DEPLOYMENT & VERCEL INTEGRATION
# ------------------------------------------
PUBLISH_STRATEGY="vercel"
VERCEL_TOKEN="your_vercel_api_token"
VERCEL_TEAM_ID="your_vercel_team_id"
VERCEL_PROJECT_ID="your_vercel_project_id"
VERCEL_OIDC_TOKEN="optional_oidc_token"
